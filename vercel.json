{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "stage-builder.vercel.app"
        }
      ],
      "destination": "https://shooters-tools.com/stage-builder",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "stage-builder.vercel.app"
        }
      ],
      "destination": "https://shooters-tools.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/ro-helper/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/tools/ro-helper/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/hit-factor",
      "destination": "/index.html"
    },
    {
      "source": "/v/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/e/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/stage-builder",
      "destination": "/index.html"
    },
    {
      "source": "/publish-policy",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/ro-helper/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/tools/ro-helper/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xml; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/sitemap-0.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xml; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/sitemap_index.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xml; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}

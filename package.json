{
  "name": "stage-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/bundle-publish-api.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "npm run lint && npm test && npm run build && npm run ro-helper:validate",
    "icons": "node scripts/generate-icons-from-preview.mjs",
    "icons:st": "node scripts/apply-st-to-icon-preview.mjs && node scripts/generate-icons-from-preview.mjs",
    "ro-helper:export-review": "node scripts/export-ro-helper-review-pack.mjs",
    "ro-helper:export-relevance": "node scripts/export-ro-helper-relevance-review.mjs",
    "ro-helper:inject-fpsu-refs": "node scripts/inject-ro-helper-fpsu-refs.mjs",
    "ro-helper:validate": "node scripts/validate-ro-helper-content.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "^2.103.2",
    "@vercel/analytics": "^2.0.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "three": "^0.183.2",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/edge": "^1.2.2",
    "@vercel/node": "^5.7.7",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.25.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fflate": "^0.8.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "workbox-window": "^7.4.0"

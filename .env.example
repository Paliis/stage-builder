# Optional: Google Analytics 4 — create a Data Stream in GA4, copy Measurement ID (G-XXXXXXXX).
# Add the same variable in Vercel → Project → Settings → Environment Variables (Production).
# Leave unset to disable GA; Vercel Web Analytics works without this.
# VITE_GA_MEASUREMENT_ID=

# Staging Vercel project only: noindex in HTML + banner in UI (do not set on production project).
# VITE_SITE_ENV=staging

# BL-001 share link (Supabase) — copy from Supabase Dashboard → Settings → API. Set in Vercel for Production/Preview.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
# Optional: local smoke test only (scripts/test-supabase-share.mjs insert/delete). Never commit; never use in Vite bundle.
# SUPABASE_SERVICE_ROLE_KEY=

# Vercel Serverless (api/publish-share.js from npm run build) — same project URL as above; use non-VITE names on the server. Optional locally if you run `vercel dev` after build.
# SUPABASE_URL=https://xxxx.supabase.co
# (or rely on VITE_SUPABASE_URL — the function reads both)
# Public base URL for copied share links (short domain or production host). Optional: if unset on Vercel,
# the API uses VERCEL_PROJECT_PRODUCTION_URL (system) so preview deploys do not embed *-team-projects in links.
# VITE_SHARE_PUBLIC_ORIGIN=https://stage-builder.vercel.app

# Optional: Google Analytics 4 — create a Data Stream in GA4, copy Measurement ID (G-XXXXXXXX).
# Add the same variable in Vercel → Project → Settings → Environment Variables (Production).
# Leave unset to disable GA; Vercel Web Analytics works without this.
# VITE_GA_MEASUREMENT_ID=

# Staging Vercel project only: noindex in HTML + banner in UI (do not set on production project).
# VITE_SITE_ENV=staging
